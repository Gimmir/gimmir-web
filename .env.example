# Copy to .env.local and fill in. Never commit .env.local.

# --- Sanity ---
# Find these in https://sanity.io/manage -> your project
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-02-01"

# Viewer token, used for Draft Mode / Visual Editing server reads.
SANITY_API_READ_TOKEN=""

# Editor token, only needed for local content seeding scripts (optional).
SANITY_API_WRITE_TOKEN=""

# Any random string; must match the secret configured on the Sanity webhook.
SANITY_REVALIDATE_SECRET=""

# --- Attio CRM (lead form) ---
ATTIO_API_KEY=""

# --- Site ---
# Production: https://gimmir.com  (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Analytics ---
# Microsoft Clarity project id (clarity.microsoft.com). Optional: the Clarity
# tag only loads when this is set, so local/dev stays clean.
NEXT_PUBLIC_CLARITY_PROJECT_ID=""
